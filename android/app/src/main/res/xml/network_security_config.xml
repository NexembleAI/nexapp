<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Default (prod): system CA store only; no cleartext, no user CAs.
         The dev flavor overrides this with src/dev to trust the mkcert CA. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
